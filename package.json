{
  "name": "coflat",
  "version": "2.0.0",
  "description": "Semantic document editor for mathematical writing",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "files": [
    "dist"
  ],
  "exports": {
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.mjs"
    },
    "./editor/style.css": "./dist/editor.css"
  },
  "scripts": {
    "dev": "vite",
    "dev:show": "vite --mode show --host localhost --port 5173 --strictPort",
    "preview": "vite preview --host 0.0.0.0",
    "dev:worktree": "node scripts/dev-worktree.mjs",
    "dev:browser": "node scripts/dev-browser.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "build": "pnpm build:app && pnpm build:editor",
    "build:app": "vite build",
    "build:coflat": "pnpm build",
    "build:editor": "tsc -p tsconfig.editor.json && vite build --config vite.editor.config.ts",
    "check:lint": "pnpm lint:errors && pnpm lint:boundaries && biome lint .",
    "check:pnpm-version": "node scripts/check-package-manager-version.mjs",
    "check:browser-fixtures": "node scripts/check-ignored-fixture-dependencies.mjs",
    "check:staged-lint": "biome lint",
    "check:types": "pnpm typecheck && pnpm typecheck:server",
    "check:static": "pnpm check:lint && pnpm check:types && pnpm check:unused",
    "check:pre-push": "pnpm check:types && pnpm lint:errors && pnpm lint:boundaries",
    "check:merge": "pnpm check:static && pnpm check:unit && pnpm check:runtime",
    "check:runtime": "pnpm test:browser:quick -- smoke && pnpm test:browser:scroll-jump",
    "check:unused": "pnpm knip",
    "check:unit": "node scripts/watched-vitest.mjs",
    "check:app-build": "pnpm build:app",
    "check:package": "pnpm build:editor && pnpm publint && pnpm size && pnpm smoke:editor-package",
    "lint": "pnpm check:lint",
    "lint:errors": "node scripts/check-bare-catch.mjs",
    "lint:boundaries": "node scripts/check-plugin-render-boundary.mjs",
    "lint:fix": "biome lint . --write",
    "test": "pnpm check:unit",
    "test:focused": "node scripts/focused-vitest.mjs",
    "test:repeat": "node scripts/test-repeat.mjs",
    "test:watch": "vitest",
    "test:changed": "vitest run --changed",
    "verify:changed": "node scripts/verify-changed.mjs",
    "issue": "node scripts/issue.mjs",
    "merge-task": "node scripts/merge-task.mjs",
    "typecheck:watch": "tsc --noEmit --watch",
    "clean": "rm -rf dist",
    "tauri:dev": "pnpm exec tauri dev",
    "tauri:build": "pnpm exec tauri build --bundles app",
    "tauri:build:dmg": "pnpm exec tauri build --bundles dmg",
    "tauri:visual:capture": "node scripts/tauri-visual-capture.mjs",
    "chrome": "pnpm chrome:app --",
    "chrome:app": "node scripts/launch-chrome.mjs --activate",
    "chrome:cdp": "node scripts/launch-chrome.mjs --no-activate",
    "chrome:test": "node scripts/test-chrome.mjs",
    "doctor:browser": "node scripts/browser-doctor.mjs",
    "browser:inspect": "node scripts/browser-inspect.mjs",
    "convert:latex": "python3 scripts/latex-to-coflat.py",
    "test:browser": "node scripts/test-regression.mjs",
    "test:browser:merged-app": "node scripts/test-regression.mjs --filter mode-switch,index-open-rich-render,headings,math-render",
    "test:browser:quick": "node scripts/browser-lane.mjs",
    "test:browser:cm6": "node scripts/browser-lane.mjs cm6-rich",
    "test:browser:cm6-rich": "node scripts/browser-lane.mjs cm6-rich",
    "test:browser:media": "node scripts/browser-lane.mjs media",
    "test:browser:navigation": "node scripts/browser-lane.mjs navigation",
    "test:browser:scroll": "node scripts/browser-lane.mjs scroll",
    "test:browser:scroll-jump": "node scripts/scroll-jump-lab.mjs --regression showcase/scroll-jump.md --simulate-wheel --step-px 180 --step-count 16 --assert-clean",
    "test:browser:scroll-jump:heavy": "node scripts/scroll-jump-lab.mjs --fixture rankdecrease/main.md --simulate-wheel --step-px 90 --step-count 24 --assert-clean",
    "test:browser:all": "node scripts/browser-lane.mjs all",
    "test:browser:dogfood": "node scripts/browser-lane.mjs dogfood",
    "test:browser:visual": "node scripts/regression-tests/visual-baselines.mjs",
    "perf:capture": "node scripts/perf-regression.mjs capture",
    "perf:compare": "node scripts/perf-regression.mjs compare",
    "perf:capture:heavy": "node scripts/perf-regression.mjs capture --heavy-doc",
    "perf:compare:heavy": "node scripts/perf-regression.mjs compare --heavy-doc",
    "perf:quick": "node scripts/perf-regression.mjs capture --iterations 1 --warmup 0 --settle-ms 100",
    "perf:quick:heavy": "node scripts/perf-regression.mjs capture --heavy-doc --iterations 1 --warmup 0 --settle-ms 100",
    "perf:dashboard": "node scripts/perf-dashboard.mjs",
    "perf:gate": "node scripts/perf-gate.mjs",
    "smoke:editor-package": "node scripts/smoke-editor-package.mjs",
    "knip": "knip",
    "publint": "publint",
    "size": "size-limit",
    "build:analyze": "vite build --config vite.editor.config.ts --mode analyze",
    "build:app:analyze": "vite build --mode analyze",
    "prepare": "lefthook install",
    "prepack": "pnpm build:editor"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ],
    "patchedDependencies": {
      "katex@0.16.38": "patches/katex@0.16.38.patch",
      "@lezer/markdown@1.6.3": "patches/@lezer__markdown@1.6.3.patch"
    }
  },
  "dependencies": {
    "@citation-js/core": "^0.7.21",
    "@citation-js/plugin-bibtex": "^0.7.21",
    "@citation-js/plugin-csl": "^0.7.22",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/dom": "^1.7.6",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-log": "^2.0.0",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.1",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "pathe": "^2.0.3",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@overleaf/codemirror-tree-view": "^0.1.3",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.0",
    "knip": "^6.6.1",
    "lefthook": "^2.1.4",
    "playwright": "^1.58.2",
    "publint": "^0.3.18",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.0"
  }
}
