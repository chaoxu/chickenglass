{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/main/crates/tauri-schema-generator/schemas/config.schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main", "document-*"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-set-focus",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "dialog:allow-open"
  ]
}
